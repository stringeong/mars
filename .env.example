# 반드시 운영 전 변경
MARS_SECRET_KEY=change-this-to-a-long-random-secret

# 호스트에 공개할 포트
MARS_SERVER_PORT=8000
MARS_WEB_PORT=5173

# 브라우저가 접근할 API 주소
VITE_API_URL=http://localhost:8000

# 호스트에서 실행 중인 Ollama에 접근
OLLAMA_URL=http://host.docker.internal:11434
MARS_DEFAULT_MODEL=gemma3:4b

MARS_TOKEN_EXPIRE_MIN=720
MARS_HEARTBEAT_TIMEOUT=30

# Docker Worker가 접근하도록 허용할 기본 호스트 폴더
MARS_WORKER_SHARED_DIR=./worker/shared
